generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────

enum ClassStatus {
  SCHEDULED
  COMPLETED
  CANCELED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELED
}

enum DiscussionStatus {
  UPCOMING
  COMPLETED
}

enum RegistrationType {
  PRIVATE
  GROUP
  DISCUSSION
}

// ─── Students & Lessons ─────────────────────────────────────────

// A student managed from the admin dashboard. Replaces data/students.json.
model Student {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String
  phone        String
  englishLevel String
  type         String // "private" | "group"
  addedAt      DateTime @default(now())

  classes  Class[]
  payments Payment[]
  debts    Debt[]

  @@index([email])
}

// A scheduled 1:1 lesson for a student. Replaces data/classes.json.
model Class {
  id          String      @id @default(cuid())
  student     Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId   String
  title       String
  description String?
  date        DateTime
  duration    Int // minutes
  status      ClassStatus @default(SCHEDULED)
  createdAt   DateTime    @default(now())

  @@index([studentId])
  @@index([date])
}

// A money received from a student. Replaces data/payments.json.
model Payment {
  id        String   @id @default(cuid())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  amount    Int
  currency  String   @default("IRR")
  note      String?
  createdAt DateTime @default(now())

  @@index([studentId])
}

// An outstanding balance owed by a student. Replaces data/debts.json.
model Debt {
  id        String   @id @default(cuid())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  amount    Int
  note      String?
  settled   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([studentId])
}

// ─── Public Booking Flow ────────────────────────────────────────

// A booking request submitted from the public booking page.
// Not tied to a Student account. Replaces data/bookings.json.
model Booking {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  topic     String
  notes     String?
  date        DateTime
  duration    Int // minutes
  status      BookingStatus @default(PENDING)
  amount      Int? // total package price (set via the payment flow)
  packageSize Int? // number of sessions in the purchased package
  createdAt   DateTime      @default(now())

  @@index([date])
}

// An admin-defined window of bookable time. Replaces data/availability.json.
// `date` is a calendar day (YYYY-MM-DD); start/end are HH:mm strings.
model Availability {
  id    String @id @default(cuid())
  date  String
  start String
  end   String

  @@unique([date, start, end])
  @@index([date])
}

// ─── Discussion Groups ──────────────────────────────────────────

// A group discussion session (upcoming or completed). Replaces data/discussions.json.
model Discussion {
  id           Int              @id @default(autoincrement())
  topic        String
  level        String
  description  String?
  duration     String // e.g. "60 min"
  status       DiscussionStatus @default(UPCOMING)
  spots        Int? // open seats (upcoming sessions)
  participants Int? // attendee count (completed sessions)
  thumbnail    String?
  points       String[] // talking points (upcoming sessions)

  dates   DiscussionDate[]
  reviews DiscussionReview[]
}

// A scheduled occurrence of a discussion (display strings, e.g. "May 28" / "20:00").
model DiscussionDate {
  id           String     @id @default(cuid())
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  discussionId Int
  date         String
  time         String

  @@index([discussionId])
}

// A teacher's written feedback for a participant of a completed discussion.
model DiscussionReview {
  id           String     @id @default(cuid())
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  discussionId Int
  name         String
  level        String
  text         String

  @@index([discussionId])
}

// ─── Leads / Registrations ──────────────────────────────────────

// A registration inquiry from the public site (private / group / discussion).
// Denormalized lead capture. Replaces data/users.json.
model Registration {
  id           String           @id @default(cuid())
  type         RegistrationType
  firstName    String
  lastName     String
  email        String
  phone        String
  englishLevel String

  // private & group
  age  String?
  job  String?

  // private
  whyPrivate String?
  purpose    String?

  // group
  whyGroup String?
  topics   String?

  // discussion
  discussionId    Int?
  discussionTopic String?
  priorExperience String?
  goals           String?

  registeredAt DateTime @default(now())

  @@index([email])
}

// ─── Admin Session ──────────────────────────────────────────────

// Single-row admin bearer token store. Replaces data/admin.json.
model AdminSession {
  id          String    @id @default("admin")
  accessToken String?
  expiredAt   DateTime?
}
